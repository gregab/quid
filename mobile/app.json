{
  "expo": {
    "name": "Aviary",
    "slug": "aviary",
    "owner": "sive-natura",
    "description": "Split expenses with friends and groups. Track who owes what and settle up easily.",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d37db65c-9f57-4fca-8ccb-2f407b315158",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "scheme": "aviary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#faf9f7",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.gregbigelow.aviary",
      "buildNumber": "1",
      "supportsTablet": true,
      "associatedDomains": ["applinks:aviary.gregbigelow.com"],
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "package": "com.gregbigelow.aviary",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#faf9f7"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "aviary.gregbigelow.com",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "expo-updates",
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "root": "app",
        "origin": false
      },
      "eas": {
        "projectId": "d37db65c-9f57-4fca-8ccb-2f407b315158"
      },
      "privacyPolicyUrl": "https://aviary.gregbigelow.com/privacy",
      "termsOfServiceUrl": "https://aviary.gregbigelow.com/terms"
    }
  }
}
