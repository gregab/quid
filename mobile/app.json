{
  "expo": {
    "name": "Aviary",
    "slug": "aviary",
    "scheme": "aviary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#faf9f7",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.gregbigelow.aviary",
      "supportsTablet": true
    },
    "android": {
      "package": "com.gregbigelow.aviary",
      "adaptiveIcon": {
        "backgroundColor": "#faf9f7"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
