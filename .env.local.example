# Prisma — direct connection (for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Full public URL of the app including basePath (no trailing slash).
# In development this defaults to http://localhost:3000/quid if unset.
# On Vercel, set this to your production URL, e.g. https://yourdomain.com/quid
NEXT_PUBLIC_SITE_URL="https://yourdomain.com/quid"
