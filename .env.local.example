# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Full public URL of the app including basePath (no trailing slash).
# In development this defaults to http://localhost:3000/aviary if unset.
# On Vercel, set this to your production URL, e.g. https://yourdomain.com/aviary
NEXT_PUBLIC_SITE_URL="https://yourdomain.com/aviary"

# Supabase service role key (server-side only — never expose to client)
# Required for admin operations like deleting auth users during account deletion.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: test account for smoke tests and Cypress E2E
# SMOKE_TEST_EMAIL="test@example.com"
# SMOKE_TEST_PASSWORD="your-password"
