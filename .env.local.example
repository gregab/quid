# Database — transaction pooler (runtime queries from serverless functions)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres"

# Database — direct connection (migrations only: npx prisma migrate dev)
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Full public URL of the app including basePath (no trailing slash).
# In development this defaults to http://localhost:3000/quid if unset.
# On Vercel, set this to your production URL, e.g. https://yourdomain.com/quid
NEXT_PUBLIC_SITE_URL="https://yourdomain.com/quid"
